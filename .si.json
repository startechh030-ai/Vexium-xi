{
  "plugin": "org.smartide.plugin.editor",
  "run": "echo 'change command from .si.json file'",
  "intelligence": {
    ".toml": {
      "enabled": true,
      "run": "taplo lsp stdio"
    },
    ".xml": {
      "enabled": true,
      "run": "lemminx"
    },
    ".yml": {
      "enabled": false,
      "run": "yaml-language-server --stdio"
    },
    ".yaml": {
      "enabled": true,
      "run": "yaml-language-server --stdio"
    }
  }
}